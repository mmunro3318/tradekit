{
  "$defs": {
    "AssetRef": {
      "properties": {
        "symbol": {
          "title": "Symbol",
          "type": "string"
        },
        "venue": {
          "title": "Venue",
          "type": "string"
        },
        "asset_class": {
          "title": "Asset Class",
          "type": "string"
        },
        "tick_size": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Tick Size"
        }
      },
      "required": [
        "symbol",
        "venue",
        "asset_class",
        "tick_size"
      ],
      "title": "AssetRef",
      "type": "object"
    },
    "Bar": {
      "properties": {
        "ts_open": {
          "format": "date-time",
          "title": "Ts Open",
          "type": "string"
        },
        "open": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Open"
        },
        "high": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "High"
        },
        "low": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Low"
        },
        "close": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Close"
        },
        "volume": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Volume"
        }
      },
      "required": [
        "ts_open",
        "open",
        "high",
        "low",
        "close",
        "volume"
      ],
      "title": "Bar",
      "type": "object"
    }
  },
  "properties": {
    "asset": {
      "$ref": "#/$defs/AssetRef"
    },
    "timeframe": {
      "title": "Timeframe",
      "type": "string"
    },
    "bars": {
      "items": {
        "$ref": "#/$defs/Bar"
      },
      "title": "Bars",
      "type": "array"
    },
    "source": {
      "title": "Source",
      "type": "string"
    },
    "stale": {
      "default": false,
      "title": "Stale",
      "type": "boolean"
    }
  },
  "required": [
    "asset",
    "timeframe",
    "bars",
    "source"
  ],
  "title": "BarSeries",
  "type": "object"
}